# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# BNB Chain RPC (server-side payment verification)
BSC_RPC_URL=https://bsc-dataseed1.bnbchain.org

# Auth (for admin panel)
BD_ENGINE_JWT_SECRET=your-jwt-secret-at-least-16-chars
BD_ENGINE_API_KEY=your-api-key

# GitHub sync (optional)
PUBLIC_REPO_PAT=your-github-pat
